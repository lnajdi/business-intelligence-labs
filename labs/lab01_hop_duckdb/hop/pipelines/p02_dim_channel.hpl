<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p02_dim_channel</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Standalone Hop-native build of warehouse.dim_channel (isolated for debugging). Replace each Dummy with the real transform. Surrogate channel_key is minted by the DB (DEFAULT nextval) - do NOT map it in Table Output. channel_name carries a UNIQUE constraint, so the dedup is mandatory.</description>
    <pipeline_type>Normal</pipeline_type>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Read staging.orders</from><to>Sort channel</to><enabled>Y</enabled></hop>
    <hop><from>Sort channel</from><to>Unique channel</to><enabled>Y</enabled></hop>
    <hop><from>Unique channel</from><to>Map channel_type</to><enabled>Y</enabled></hop>
    <hop><from>Map channel_type</from><to>Select and rename</to><enabled>Y</enabled></hop>
    <hop><from>Select and rename</from><to>Write dim_channel</to><enabled>Y</enabled></hop>
  </order>

  <transform><name>Read staging.orders</name><type>Dummy</type><description>Replace with Table Input: SELECT channel FROM staging.orders (connection DuckDB_Lab1).</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>64</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Sort channel</name><type>Dummy</type><description>Replace with Sort Rows: channel ASC. Required before Unique Rows.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>240</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Unique channel</name><type>Dummy</type><description>Replace with Unique Rows: compare on channel (= SELECT DISTINCT channel).</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>416</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Map channel_type</name><type>Dummy</type><description>Replace with Value Mapper: channel -> channel_type (Online->Digital, Store->Physical, Partner->Indirect). Default upon non-matching = Unknown.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>592</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Select and rename</name><type>Dummy</type><description>Replace with Select Values: rename channel -> channel_name; final order = dim_channel schema WITHOUT channel_key (channel_name, channel_type).</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>768</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Write dim_channel</name><type>Dummy</type><description>Replace with Table Output: warehouse.dim_channel, truncate = Y. Do NOT map channel_key (DB fills it via DEFAULT nextval).</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>944</xloc><yloc>80</yloc></GUI></transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
