<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p05_load_budget</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load sales_budget.csv into warehouse.fact_budget. Reference skeleton — validate in Hop GUI.</description>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DATA_DIR</name>
        <default_value>data/raw</default_value>
        <description>Root folder of raw CSV files</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Read sales_budget.csv</from> <to>Lookup category name</to>   <enabled>Y</enabled></hop>
    <hop><from>Lookup category name</from>  <to>Lookup channel key</to>     <enabled>Y</enabled></hop>
    <hop><from>Lookup channel key</from>    <to>Write fact_budget</to>      <enabled>Y</enabled></hop>
  </order>

  <transform>
    <name>Read sales_budget.csv</name>
    <type>CSVInput</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${DATA_DIR}/sales_budget.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding/>
    <fields>
      <field><name>budget_id</name>     <type>Integer</type><trim_type>none</trim_type></field>
      <field><name>year</name>          <type>Integer</type><trim_type>none</trim_type></field>
      <field><name>month</name>         <type>Integer</type><trim_type>none</trim_type></field>
      <field><name>category_id</name>   <type>Integer</type><trim_type>none</trim_type></field>
      <field><name>channel</name>       <type>String</type> <trim_type>none</trim_type></field>
      <field><name>budget_amount</name> <type>Number</type> <trim_type>none</trim_type></field>
      <field><name>budget_qty</name>    <type>Integer</type><trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>64</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Lookup category name</name>
    <type>DatabaseLookup</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <schema>raw</schema>
    <table>categories</table>
    <orderby/>
    <fail_on_multiple>N</fail_on_multiple>
    <eat_row_on_failure>N</eat_row_on_failure>
    <cache>Y</cache>
    <cache_size>0</cache_size>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <key><name>category_id</name><field>category_id</field><condition>=</condition><name2/></key>
      <value><name>category_name</name><rename>category_name</rename><default/><type>String</type></value>
    </lookup>
    <attributes/>
    <GUI><xloc>240</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Lookup channel key</name>
    <type>DatabaseLookup</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <schema>warehouse</schema>
    <table>dim_channel</table>
    <orderby/>
    <fail_on_multiple>N</fail_on_multiple>
    <eat_row_on_failure>N</eat_row_on_failure>
    <cache>Y</cache>
    <cache_size>0</cache_size>
    <cache_load_all>Y</cache_load_all>
    <lookup>
      <key><name>channel</name><field>channel_name</field><condition>=</condition><name2/></key>
      <value><name>channel_key</name><rename>channel_key</rename><default/><type>Integer</type></value>
    </lookup>
    <attributes/>
    <GUI><xloc>420</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Write fact_budget</name>
    <type>TableOutput</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <schema>warehouse</schema>
    <table>fact_budget</table>
    <truncate>Y</truncate>
    <specify_fields>Y</specify_fields>
    <commit>1000</commit>
    <use_batch>Y</use_batch>
    <return_keys>N</return_keys>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <ignore_errors>N</ignore_errors>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <fields>
      <field><column_name>budget_id</column_name>     <stream_name>budget_id</stream_name></field>
      <field><column_name>year</column_name>           <stream_name>year</stream_name></field>
      <field><column_name>month_num</column_name>      <stream_name>month</stream_name></field>
      <field><column_name>category_id</column_name>   <stream_name>category_id</stream_name></field>
      <field><column_name>category_name</column_name> <stream_name>category_name</stream_name></field>
      <field><column_name>channel_key</column_name>   <stream_name>channel_key</stream_name></field>
      <field><column_name>channel_name</column_name>  <stream_name>channel</stream_name></field>
      <field><column_name>budget_amount</column_name> <stream_name>budget_amount</stream_name></field>
      <field><column_name>budget_qty</column_name>    <stream_name>budget_qty</stream_name></field>
    </fields>
    <attributes/>
    <GUI><xloc>600</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
