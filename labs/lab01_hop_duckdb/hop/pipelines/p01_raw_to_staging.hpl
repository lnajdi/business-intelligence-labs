<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p01_raw_to_staging</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load 6 CSV files into staging with field validation and city normalisation.
NOTE: This is a reference skeleton — open and re-save in Hop GUI to validate.</description>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DATA_DIR</name>
        <default_value>data/raw</default_value>
        <description>Root folder of raw CSV files</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Read customers.csv</from>    <to>Validate customer_id</to>      <enabled>Y</enabled></hop>
    <hop><from>Validate customer_id</from>  <to>Normalize city</to>            <enabled>Y</enabled></hop>
    <hop><from>Normalize city</from>        <to>Write staging.customers</to>   <enabled>Y</enabled></hop>
    <hop><from>Validate customer_id</from>  <to>Rejects customers</to>         <enabled>Y</enabled></hop>
    <!-- Repeat hops for other 5 table flows below -->
  </order>

  <!-- ======================================================== -->
  <!--  CUSTOMERS FLOW (pattern — repeat for other 5 tables)    -->
  <!-- ======================================================== -->
  <transform>
    <name>Read customers.csv</name>
    <type>CSVInput</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${DATA_DIR}/customers.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding/>
    <fields>
      <field><name>customer_id</name>   <type>Integer</type><trim_type>none</trim_type></field>
      <field><name>customer_name</name> <type>String</type> <trim_type>none</trim_type></field>
      <field><name>email</name>         <type>String</type> <trim_type>none</trim_type></field>
      <field><name>city</name>          <type>String</type> <trim_type>both</trim_type></field>
      <field><name>country</name>       <type>String</type> <trim_type>none</trim_type></field>
      <field><name>signup_date</name>   <type>Date</type>   <format>yyyy-MM-dd</format><trim_type>none</trim_type></field>
      <field><name>segment</name>       <type>String</type> <trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>64</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Validate customer_id</name>
    <type>FilterRows</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Normalize city</send_true_to>
    <send_false_to>Rejects customers</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>customer_id</leftvalue>
        <function>IS NOT NULL</function>
        <rightvalue/>
      </condition>
    </compare>
    <attributes/>
    <GUI><xloc>240</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Normalize city</name>
    <type>ValueMapper</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <field_to_use>city</field_to_use>
    <target_field>city</target_field>
    <non_match_default>Unknown</non_match_default>
    <target_type/>
    <fields>
      <field><source_value>CASABLANCA</source_value>  <target_value>Casablanca</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>casablanca</source_value>  <target_value>Casablanca</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>RABAT</source_value>       <target_value>Rabat</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>Rabat</source_value>       <target_value>Rabat</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>MARRAKECH</source_value>   <target_value>Marrakech</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>Marrakech</source_value>   <target_value>Marrakech</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>FES</source_value>         <target_value>Fes</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>FEZ</source_value>         <target_value>Fes</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>TANGIER</source_value>     <target_value>Tangier</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>TANGER</source_value>      <target_value>Tangier</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
      <field><source_value>AGADIR</source_value>      <target_value>Agadir</target_value><empty_string_equals_null>Y</empty_string_equals_null></field>
    </fields>
    <attributes/>
    <GUI><xloc>420</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Write staging.customers</name>
    <type>TableOutput</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <schema>staging</schema>
    <table>customers</table>
    <truncate>Y</truncate>
    <specify_fields>N</specify_fields>
    <commit>1000</commit>
    <use_batch>Y</use_batch>
    <return_keys>N</return_keys>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <ignore_errors>N</ignore_errors>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <attributes/>
    <GUI><xloc>600</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Rejects customers</name>
    <type>TextFileOutput</type>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <footer>N</footer>
    <format>UNIX</format>
    <encoding>UTF-8</encoding>
    <file>
      <name>data/processed/rejects_customers</name>
      <extention>csv</extention>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
    </file>
    <fields/>
    <attributes/>
    <GUI><xloc>240</xloc><yloc>240</yloc></GUI>
  </transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
