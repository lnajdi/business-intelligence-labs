<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p03_build_facts</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Skeleton for Hop-native fact loads. Build lookups, filters, and measure calculations with Hop transforms.</description>
    <pipeline_type>Normal</pipeline_type>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Start</from><to>Build fact_sales with Hop steps</to><enabled>Y</enabled></hop>
    <hop><from>Build fact_sales with Hop steps</from><to>Build fact_stock with Hop steps</to><enabled>Y</enabled></hop>
  </order>

  <transform><name>Start</name><type>Dummy</type><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>64</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build fact_sales with Hop steps</name><type>Dummy</type><description>Add Table Input staging.order_items, Database Lookups to staging.orders and dimensions, Filter Rows, Calculator, Table Output warehouse.fact_sales.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>260</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build fact_stock with Hop steps</name><type>Dummy</type><description>Add Table Input staging.stock_movements, Database Lookups to dimensions, Filter Rows, Calculator qty_in/qty_out, Table Output warehouse.fact_stock.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>520</xloc><yloc>80</yloc></GUI></transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
