<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p03_build_facts</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Build warehouse.fact_sales and warehouse.fact_stock. Reference skeleton — validate in Hop GUI.</description>
    <pipeline_type>Normal</pipeline_type>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Start</from>             <to>Build fact_sales</to>  <enabled>Y</enabled></hop>
    <hop><from>Build fact_sales</from>  <to>Build fact_stock</to>  <enabled>Y</enabled></hop>
  </order>

  <transform>
    <name>Start</name>
    <type>Dummy</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <attributes/>
    <GUI><xloc>64</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Build fact_sales</name>
    <type>ExecSql</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <quoteString>N</quoteString>
    <sql>TRUNCATE warehouse.fact_sales;
INSERT INTO warehouse.fact_sales SELECT oi.order_item_id,dd.date_key,dc.customer_key,dp.product_key,dch.channel_key,o.order_id,oi.quantity,oi.unit_price,dp.cost_price,oi.discount_amount,(oi.quantity*oi.unit_price),(oi.quantity*oi.unit_price-oi.discount_amount),(oi.quantity*dp.cost_price),(oi.quantity*oi.unit_price-oi.discount_amount-oi.quantity*dp.cost_price),o.order_status,CURRENT_TIMESTAMP FROM staging.order_items oi JOIN staging.orders o ON oi.order_id=o.order_id JOIN warehouse.dim_date dd ON o.order_date=dd.date_actual JOIN warehouse.dim_customer dc ON o.customer_id=dc.customer_id_src JOIN warehouse.dim_product dp ON oi.product_id=dp.product_id_src JOIN warehouse.dim_channel dch ON o.channel=dch.channel_name;</sql>
    <set_params>N</set_params>
    <insert_field/><update_field/><delete_field/><read_field/>
    <attributes/>
    <GUI><xloc>240</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Build fact_stock</name>
    <type>ExecSql</type>
    <distribute>Y</distribute><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <quoteString>N</quoteString>
    <sql>TRUNCATE warehouse.fact_stock;
INSERT INTO warehouse.fact_stock SELECT sm.movement_id,dd.date_key,dp.product_key,CASE sm.movement_type WHEN 'IN' THEN sm.quantity ELSE 0 END,CASE sm.movement_type WHEN 'OUT' THEN sm.quantity ELSE 0 END,sm.warehouse,CURRENT_TIMESTAMP FROM staging.stock_movements sm JOIN warehouse.dim_date dd ON sm.movement_date=dd.date_actual JOIN warehouse.dim_product dp ON sm.product_id=dp.product_id_src;</sql>
    <set_params>N</set_params>
    <insert_field/><update_field/><delete_field/><read_field/>
    <attributes/>
    <GUI><xloc>420</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
