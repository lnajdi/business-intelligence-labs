<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p02_build_dims</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Skeleton for Hop-native dimension loads from staging.* to warehouse.*. Use ExecSql only for optional TRUNCATE plumbing.</description>
    <pipeline_type>Normal</pipeline_type>
    <capture_transform_performance>N</capture_transform_performance>
  </info>

  <order>
    <hop><from>Start</from><to>Build dim_date with Hop steps</to><enabled>Y</enabled></hop>
    <hop><from>Build dim_date with Hop steps</from><to>Build dim_customer with Hop steps</to><enabled>Y</enabled></hop>
    <hop><from>Build dim_customer with Hop steps</from><to>Build dim_product with Hop steps</to><enabled>Y</enabled></hop>
    <hop><from>Build dim_product with Hop steps</from><to>Build dim_channel with Hop steps</to><enabled>Y</enabled></hop>
  </order>

  <transform><name>Start</name><type>Dummy</type><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>64</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build dim_date with Hop steps</name><type>Dummy</type><description>Add Generate Rows/Sequence, Calculator, Select Values, Table Output.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>240</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build dim_customer with Hop steps</name><type>Dummy</type><description>Add Table Input, Filter Rows, Sort Rows, Unique Rows, Value Mapper, Add Sequence, Table Output.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>440</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build dim_product with Hop steps</name><type>Dummy</type><description>Add Table Input, Database Lookup staging.categories, Filter Rows, Add Sequence, Table Output.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>660</xloc><yloc>80</yloc></GUI></transform>
  <transform><name>Build dim_channel with Hop steps</name><type>Dummy</type><description>Add Table Input, Unique Rows, Value Mapper, Add Sequence, Table Output.</description><distribute>Y</distribute><copies>1</copies><partitioning><method>none</method><schema_name/></partitioning><attributes/><GUI><xloc>880</xloc><yloc>80</yloc></GUI></transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
